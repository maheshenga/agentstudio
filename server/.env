APP_NAME=nextjs-server
APP_PORT=3000
APP_API_PREFIX=api
DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=fssoa-net
DB_SYNC=false
DB_LOGGING=false

JWT_SECRET=this_is_jwt_secret_change_me_32_chars_min
JWT_EXPIRES_IN=2h
LOGIN_CAPTCHA_ENABLED=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

CORS_MODE=off
CORS_ORIGINS=
CORS_CREDENTIALS=false

SWAGGER_ENABLED=false
SWAGGER_USERNAME=
SWAGGER_PASSWORD=
SWAGGER_TITLE=FssAdmin
SWAGGER_DESCRIPTION=FssAdmin API 文档
SWAGGER_VERSION=1.0.0

# ========== 文件上传 ==========
FILE_STORAGE=local
FILE_UPLOAD_DIR=../upload
FILE_DOMAIN=http://localhost:3000
FILE_SERVE_ROOT=/profile
FILE_MAX_SIZE=10
FILE_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp,pdf,txt,zip,doc,xls

LOG_LEVEL=info
LOG_DIR=logs
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_HEALTH_LOG_ENABLED=false
LOG_DEPENDENCY_CHECK_INTERVAL_MS=30000
LOG_MAX_FILE_SIZE_MB=20
LOG_RETENTION_DAYS=30

# AI 并发流控制(每 Worker)
AI_MAX_CONCURRENT_STREAMS=20

TAIXU_QDRANT_URL=http://localhost:6333
TAIXU_QDRANT_COLLECTION_PREFIX=agent_rag_
TAIXU_QDRANT_VECTOR_SIZE=1024
TAIXU_QDRANT_TIMEOUT=30
TAIXU_QDRANT_EMBED_BATCH=64

TAIXU_NEO4J_BOLT_URL=bolt://localhost:7687
TAIXU_NEO4J_HTTP_URL=http://localhost:7474
TAIXU_NEO4J_USERNAME=system
TAIXU_NEO4J_PASSWORD=
TAIXU_NEO4J_LABEL_PREFIX=agent_graph_

# ========== 图谱（LLM 实体关系抽取）==========
# 总开关：默认 false 关闭以大幅提速入库（chunk 节点与向量检索不受影响）。
# 需要 GraphRAG 实体图时设为 true，并确保 RAG 设置里 graph=open。
TAIXU_GRAPH_ENABLED=false
# 开启后图谱抽取的并发数（对齐 taixu 线程池）
TAIXU_GRAPH_CONCURRENCY=5
# 图谱抽取使用的粗粒度分块大小（越大 LLM 调用越少、越快）
TAIXU_GRAPH_CHUNK_SIZE=2400

# 文档索引队列：默认不要求登录才消费（false）；若设为 true 则必须有人登录后台才会处理队列
TAIXU_DOC_INDEX_REQUIRE_LOGIN=false

TAIXU_TAVILY_API_KEY=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
