{
  "name": "nextjs-server",
  "version": "2.0.0",
  "description": "NestJS backend service for FssAdmin",
  "private": true,
  "license": "mit",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development bun run --watch src/main.ts",
    "dev:debug": "cross-env NODE_ENV=development bun run --inspect --watch src/main.ts",
    "dev:node": "cross-env NODE_ENV=development nest start --watch",
    "dev:nest": "cross-env NODE_ENV=development nest start --watch",
    "dev:prd": "cross-env NODE_ENV=production bun run --watch src/main.ts",
    "dev:prd:node": "cross-env NODE_ENV=production tsx watch src/main.ts",
    "dev:prd:nest": "cross-env NODE_ENV=production nest start --watch",
    "start": "pnpm run dev",
    "start:test": "cross-env NODE_ENV=test bun run --watch src/main.ts",
    "start:test:nest": "cross-env NODE_ENV=test nest start --watch",
    "start:debug:nest": "nest start --debug --watch",
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "rimraf dist tsconfig.tsbuildinfo",
    "build:nest": "cross-env NODE_ENV=development nest build",
    "build:prd": "cross-env NODE_ENV=production tsc -p tsconfig.build.json",
    "build:prd:nest": "cross-env NODE_ENV=production nest build",
    "build:bun": "bun build src/main.ts --outdir dist --target bun --minify-whitespace --minify-syntax --external yamlparser --external mysql2 --external winston --external winston-daily-rotate-file --external class-transformer --external @nestjs/microservices --external @nestjs/platform-socket.io --external expo-sqlite --external better-sqlite3 --external sqlite3 --external pg --external pg-native --external pg-query-stream --external oracledb --external mongodb --external react-native-sqlite-storage --external @sap/hana-client --external hdb-pool --external sql.js",
    "bundle:bun": "bun build src/main.ts --outdir out --target bun --minify-whitespace --minify-syntax --external class-transformer --external yamlparser --external @nestjs/microservices --external @nestjs/platform-socket.io --external expo-sqlite --external better-sqlite3 --external sqlite3 --external pg --external pg-native --external pg-query-stream --external oracledb --external mongodb --external react-native-sqlite-storage --external @sap/hana-client --external hdb-pool --external sql.js && echo 打包完成。运行: bun out/main.js",
    "typecheck": "tsc --noEmit",

    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "start:prod:bun": "cross-env NODE_ENV=production bun dist/main.js",
    "prod": "cross-env NODE_ENV=production pm2-runtime start ecosystem.config.cjs --interpreter bun",
    "prod:pm2": "cross-env NODE_ENV=production pm2 restart ecosystem.config.cjs --interpreter bun",
    "prod:stop": "pm2 stop ecosystem.config.cjs",
    "start:pm2": "cross-env NODE_ENV=production pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop nextjs-server",
    "restart:pm2": "pm2 restart nextjs-server",
    "logs:pm2": "pm2 logs nextjs-server",
    "init:auth": "node -r tsconfig-paths/register dist/auth/cli/init-auth.cli.js",
    "init:auth:dev": "pnpm run build && pnpm run init:auth",
    "verify:api": "node -r tsconfig-paths/register dist/api-verifier/cli/verify-apis.cli.js",
    "verify:api:dev": "pnpm run build && pnpm run verify:api",
    "db:verify-init": "node scripts/verify-db-init.cjs",
    "test": "jest",
    "verify:saas-readiness": "jest -- saas-main-flow.integration.spec.ts saas-route-consistency.spec.ts saas-tenant.controller.spec.ts saas-platform.controller.spec.ts saas-payment.controller.spec.ts saas-visible-text-encoding.spec.ts saas-resource-pack.service.spec.ts save-saas-resource-pack.dto.spec.ts align-saas-resource-pack-crud-permissions.spec.ts --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:bun": "bun test",
    "typeorm": "typeorm-ts-node-commonjs -d ./src/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:generate": "typeorm-ts-node-commonjs -d ./src/data-source.ts migration:generate",
    "migration:run": "typeorm-ts-node-commonjs -d ./src/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d ./src/data-source.ts migration:revert",
    "lint": "eslint .",
    "cleanlog": "rimraf logs"
  },
  "dependencies": {
    "@golevelup/nestjs-modules": "^2.0.1",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/neo4j": "^0.1.10",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.3",
    "@langchain/qdrant": "^1.0.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-ws": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.2",
    "@nestjs/websockets": "^11.1.27",
    "@qdrant/js-client-rest": "^1.18.0",
    "archiver": "^7.0.1",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cron": "^3.5.0",
    "cross-env-plugins": "^1.0.21",
    "dayjs": "^1.11.21",
    "dotenv": "^16.6.1",
    "eventsource-parser": "^3.1.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "fs-extra": "^11.3.5",
    "helmet": "^7.2.0",
    "html-to-text": "^10.0.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "langchain": "^1.5.2",
    "lodash": "^4.18.1",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "mysql2": "^3.22.5",
    "neo4j-driver": "^6.1.0",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "path-to-regexp": "^8.4.2",
    "pdf-parse": "^2.4.5",
    "qdrant-client": "^0.0.1",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.2",
    "sensitive-word-tool": "^1.1.10",
    "svg-captcha": "^1.4.0",
    "typeorm": "^1.0.0",
    "undici": "^8.5.0",
    "useragent": "^2.3.0",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0",
    "xss": "^1.0.15",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/archiver": "^6.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cron": "^2.4.3",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^2.0.16",
    "@types/useragent": "^2.3.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "request": "^2.88.2",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "yamlparser": "^0.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "esbuild"
    ]
  }
}
