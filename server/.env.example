# 运行环境，可选值：development、test、production
NODE_ENV=development

# true=正常模式；false=只读模式（禁止 POST/PUT/DELETE/PATCH，白名单除外）
DEBUG=true

# 应用名称，会出现在启动信息、日志记录和健康检查中
APP_NAME=FssAdmin-Api

# HTTP 服务监听端口
APP_PORT=48137

# 全局 API 前缀，例如 api 对应 /api，api_v2 对应 /api_v2
APP_API_PREFIX=

# MySQL 主机地址，示例值为文档保留地址，可安全提交
DB_HOST=127.0.0.1

# MySQL 端口
DB_PORT=3306

# MySQL 用户名，示例值请按实际环境替换
DB_USERNAME=root

# MySQL 密码，示例值为随机占位，请勿使用真实生产密码
DB_PASSWORD=change_me_db_password

# MySQL 数据库名
DB_NAME=fssoa-net

# 是否在启动时根据 Entity 自动同步表结构；生产环境必须为 false
DB_SYNC=false

# 是否输出 TypeORM SQL 日志；生产环境建议为 false，避免日志过多或泄露敏感信息
DB_LOGGING=true

# JWT 签名密钥，生产环境必须替换为强随机值，长度至少 32 位
JWT_SECRET=this_is_jwt_secret_change_me_32_chars_min

# JWT 过期时间，例如 60s、30m、2h、7d
JWT_EXPIRES_IN=2h

# Login captcha switch. Set false only for trusted local/dev environments.
LOGIN_CAPTCHA_ENABLED=true

# Swagger 文档开关
SWAGGER_ENABLED=false
# Swagger Basic Auth 用户名（留空则不启用认证）
SWAGGER_USERNAME=
# Swagger Basic Auth 密码
SWAGGER_PASSWORD=
# Swagger 文档标题
SWAGGER_TITLE=FssAdmin
# Swagger 文档描述
SWAGGER_DESCRIPTION=FssAdmin API 文档
# Swagger 文档版本
SWAGGER_VERSION=1.0.0

# ========== 文件上传 ==========
# 文件存储方式：local（本地）或 cos（腾讯云对象存储）
FILE_STORAGE=local
# 文件上传后存储目录，相对路径（相对本项目根目录）或绝对路径
FILE_UPLOAD_DIR=../upload
# 文件服务器地址，开发环境 http://localhost:3000，生产环境请配置可访问域名
FILE_DOMAIN=http://localhost:3000
# 文件虚拟路径前缀，必须以 / 开头，如 /profile
FILE_SERVE_ROOT=/profile
# 文件大小限制，单位 M
FILE_MAX_SIZE=10
# 文件格式
FILE_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp,pdf,txt,zip,doc,xls

# App marketplace package storage. P0 serves approved static apps only.
APP_PACKAGE_DIR=../upload/app-packages
APP_PUBLIC_DIR=../upload/app-public
APP_PUBLIC_PREFIX=/apps-static/
APP_PACKAGE_MAX_SIZE_MB=50
APP_PACKAGE_MAX_FILES=500
APP_PACKAGE_MAX_FILE_MB=25
APP_PACKAGE_MAX_UNCOMPRESSED_MB=200
APP_PACKAGE_MAX_COMPRESSION_RATIO=100

# Reviewed service runtimes remain disabled by default. PM2 is for development only;
# production requires a complete rootless Podman configuration.
APP_SERVICE_RUNTIME_ENABLED=false
APP_SERVICE_RUNTIME_DRIVER=pm2
APP_SERVICE_RUNTIME_DIR=../upload/app-service-runtime
APP_SERVICE_RUNTIME_USER=
APP_SERVICE_PM2_HOME=
APP_SERVICE_PM2_COMMAND=pm2
APP_SERVICE_RUNTIME_INTERPRETER=node
APP_SERVICE_PODMAN_COMMAND=/usr/bin/podman
APP_SERVICE_PODMAN_IMAGE=
APP_SERVICE_PODMAN_HOME=
APP_SERVICE_PODMAN_XDG_RUNTIME_DIR=
APP_SERVICE_SOCKET_DIR=
APP_SERVICE_MEMORY_MB=256
APP_SERVICE_CPU_LIMIT=1
APP_SERVICE_PIDS_LIMIT=64
APP_SERVICE_TMPFS_MB=16
APP_SERVICE_CONTAINER_UID=65532
APP_SERVICE_REQUEST_TIMEOUT_MS=15000
APP_SERVICE_MAX_BODY_MB=2
APP_SERVICE_HEALTH_SUCCESS_COUNT=3
APP_SERVICE_PORT_MIN=20000
APP_SERVICE_PORT_MAX=39999

# Certified developer service plugins remain disabled until P11 rollout is approved.
APP_DEVELOPER_SERVICE_ENABLED=false
APP_DEVELOPER_SERVICE_CONCURRENCY=20
APP_DEVELOPER_SERVICE_RATE_PER_MINUTE=60
APP_DEVELOPER_SERVICE_CIRCUIT_FAILURES=5
APP_DEVELOPER_SERVICE_CIRCUIT_OPEN_SECONDS=60
APP_DEVELOPER_SERVICE_LOG_RETENTION_DAYS=7
APP_COMMERCE_ENABLED=false

# 认证初始化命令使用的默认管理员密码；生产环境必须通过安全方式注入，不要使用示例值
ADMIN_PASSWORD=change_me_admin_password_32_chars

# 是否在认证初始化命令中重置已有 admin 密码
ADMIN_RESET_PASSWORD=false

# Redis 主机地址，示例值为文档保留地址，可安全提交
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 密码，示例值为随机占位；如果 Redis 无密码可留空
REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DB=3

# CORS 跨域模式：off=关闭跨域，all/open=允许任意来源，list=仅允许 CORS_ORIGINS 中的来源
CORS_MODE=off

# CORS_MODE=list 时生效，多个 Origin 使用英文逗号分隔；示例值可安全提交
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# 是否允许跨域请求携带凭证；Bearer Token 不需要开启，使用 Cookie 跨域时才需要 true
CORS_CREDENTIALS=false

# ========== SaaS payment / Alipay sandbox ==========
# Development-only local payment confirmation endpoint. Keep false in shared/prod env.
SAAS_DEV_PAYMENT_CONFIRM_ENABLED=false
# Set true after sandbox keys and callback URLs are configured.
ALIPAY_ENABLED=false
# Alipay app id, for example 2021000123456789.
ALIPAY_APP_ID=
# PKCS8 app private key. Use a single line with \n escapes when storing in .env.
ALIPAY_PRIVATE_KEY=
# Alipay public key. Use a single line with \n escapes when storing in .env.
ALIPAY_PUBLIC_KEY=
# Backend callback URL reachable by Alipay.
ALIPAY_NOTIFY_URL=http://127.0.0.1:8181/api/saas/payment/alipay/notify
# Frontend return URL after browser payment.
ALIPAY_RETURN_URL=http://127.0.0.1:5731/#/tenant-saas/plan
# Sandbox gateway. Replace with the production gateway when going live.
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 应用日志最低输出级别，可选值：fatal、error、warn、info、debug
LOG_LEVEL=info

# 日志文件根目录
LOG_DIR=logs

# 是否输出控制台日志
LOG_CONSOLE_ENABLED=true

# 是否写入本地文件日志
LOG_FILE_ENABLED=true

# 是否记录 /health 成功请求日志；默认 false 用于避免健康检查刷屏
LOG_HEALTH_LOG_ENABLED=false

# MySQL / Redis 依赖状态检查间隔，单位：毫秒
LOG_DEPENDENCY_CHECK_INTERVAL_MS=30000

# 单个日志文件最大大小，单位：MB；超过后会生成同小时分片文件
LOG_MAX_FILE_SIZE_MB=20

# 日志保留天数；超过该天数的日期目录会被自动清理
LOG_RETENTION_DAYS=30

# ========== 内存监控 ==========
# RSS/堆 超限是否退出进程（生产 PM2 建议 true，本地 Bun 开发建议 false）
# MEMORY_FATAL_EXIT=false
# RSS 警告/致命阈值（MB）；Bun 默认 768/1536，Node 默认 300/450
# MEMORY_RSS_WARN_MB=768
# MEMORY_RSS_FATAL_MB=1536
# 堆使用率警告/致命阈值（0-100）
# MEMORY_HEAP_WARN_PERCENT=85
# MEMORY_HEAP_FATAL_PERCENT=95
# Node 下 RSS 参与致命判断；Bun 默认关闭（设 true 可强制启用）
# MEMORY_RSS_FATAL_ENABLED=true

# ========== AI / DeepSeek（可选）==========

# AI 并发流控制(每 Worker)
AI_MAX_CONCURRENT_STREAMS=20

# ========== TaiXu（可选）==========
TAIXU_QDRANT_URL=http://localhost:6333
TAIXU_QDRANT_COLLECTION_PREFIX=agent_rag_
TAIXU_QDRANT_VECTOR_SIZE=1024
TAIXU_QDRANT_TIMEOUT=30
TAIXU_QDRANT_EMBED_BATCH=64


TAIXU_NEO4J_BOLT_URL=bolt://localhost:7687
TAIXU_NEO4J_HTTP_URL=http://localhost:7474
TAIXU_NEO4J_USERNAME=neo4j
TAIXU_NEO4J_PASSWORD=
TAIXU_NEO4J_LABEL_PREFIX=agent_graph_


TAIXU_TAVILY_API_KEY=
TAIXU_DOC_SAVE_DIR=../upload/taixu/documents

TAIXU_MCP_AMAP_KEY=
TAIXU_LLM_PROVIDER=ollama

TAIXU_OPENAI_API_KEY=
TAIXU_OPENAI_BASE_URL=
TAIXU_OPENAI_MODEL=gpt-4o-mini
TAIXU_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TAIXU_OPENAI_IMAGE_MODEL=gpt-image-1
TAIXU_OLLAMA_BASE_URL=http://localhost:11434
TAIXU_OLLAMA_MODEL=llama3
TAIXU_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ========== 图谱（LLM 实体关系抽取）==========
# 总开关：默认 false 关闭以大幅提速入库（chunk 节点与向量检索不受影响）。
# 需要 GraphRAG 实体图时设为 true，并确保 RAG 设置里 graph=open。
TAIXU_GRAPH_ENABLED=false
# 开启后图谱抽取的并发数（对齐 taixu 线程池）
TAIXU_GRAPH_CONCURRENCY=5
# 图谱抽取使用的粗粒度分块大小（越大 LLM 调用越少、越快）
TAIXU_GRAPH_CHUNK_SIZE=2400
